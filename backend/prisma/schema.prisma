datasource db {
  provider = "postgresql"
  // Remova a linha 'url' daqui, o Prisma 7 vai ler do arquivo de configuração
}

generator client {
  provider = "prisma-client-js"
}

// =======================
// ENUMS (Listas de Opções)
// =======================

enum Role {
  USER
  AFFILIATE
  ADMIN
}

enum Category {
  RENT
  GROCERIES
  TRANSPORT
  HEALTH
  UTILITIES
  LEISURE
  INCOME // Adicionado para receitas financeiras
}

enum ChecklistStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum Plan {
  FREE
  PRO
  LIFETIME
}

enum SubStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

// =======================
// MODELS (Tabelas do Banco)
// =======================

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password_hash String
  name          String?        // Adicionado: Nome do usuário
  cpf           String?        @unique // Adicionado: Para credibilidade/venda
  role          Role           @default(USER)
  appMode       String         @default("PLANNER") // PLANNER or RESIDENT
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relações
  households    Household[]
  scenarios     Scenario[]
  subscriptions Subscription[]
  affiliate     Affiliate?
  transactions  Transaction[]   // Adicionado: Para a gestão financeira mensal
}

model Household {
  id        String   @id @default(uuid())
  userId    String
  name      String?  // Adicionado: Nome do familiar (Ex: "Esposa", "Filho")
  age       Int?     // Adicionado: Idade
  type      String   @default("DEPENDENT") // Adicionado: Tipo de dependente
  works     Boolean  @default(false)      // Adicionado: Se trabalha (ajuda no custo)
  
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction { // NOVA TABELA: Para o controle mensal de gastos
  id          String   @id @default(uuid())
  description String
  amount      Float    // Valor real
  currency    String   @default("BRL") // EUR, BRL, CAD
  type        String   // "INCOME" ou "EXPENSE"
  category    Category
  date        DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Scenario {
  id            String         @id @default(uuid())
  userId        String
  originCountry String
  destCountry   String
  destCity      String
  currency      String         @default("USD")
  savingsBRL    Float          @default(0) // Seu saldo atual guardado
  incomeBRL     Float          @default(0) // Quanto você ganha hoje
  bufferPercent Float          @default(15)
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  overrides     CostOverride[]
  checklist     ChecklistItem[]
}

model Affiliate { // TABELA MELHORADA: Para o sistema de vendas
  id              String   @id @default(uuid())
  userId          String   @unique
  code            String   @unique
  balance         Float    @default(0.0) // Saldo para saque
  pixKey          String?  // Chave PIX do afiliado
  status          String   @default("PENDING") // PENDING, ACTIVE
  totalEarned     Float    @default(0.0)

  user            User     @relation(fields: [userId], references: [id])
  clicks          AffiliateClick[]
  conversions     AffiliateConversion[]
  payouts         AffiliatePayout[]
}

model AffiliateClick {
  id           String    @id @default(uuid())
  affiliateId  String
  ipAddress    String?
  userAgent    String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime  @default(now())

  affiliate    Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId, createdAt])
}

model AffiliateConversion {
  id           String    @id @default(uuid())
  affiliateId  String
  amount       Float
  commission   Float
  status       String    @default("PENDING") // PENDING, APPROVED, PAID
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  affiliate    Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId, status])
}

model AffiliatePayout {
  id           String    @id @default(uuid())
  affiliateId  String
  amount       Float
  status       String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  pixKey       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  affiliate    Affiliate @relation(fields: [affiliateId], references: [id])
}

// Tabelas de apoio (Mantidas do original)
model CostBaseline {
  id        String   @id @default(uuid())
  country   String
  city      String
  category  Category
  min       Float
  avg       Float
  max       Float
  updatedAt DateTime @updatedAt
}

model CostOverride {
  id         String   @id @default(uuid())
  scenarioId String
  category   Category
  value      Float
  currency   String
  scenario   Scenario @relation(fields: [scenarioId], references: [id])
}

model FxRate {
  id     String   @id @default(uuid())
  base   String
  target String
  rate   Float
  asOf   DateTime
}

model ChecklistItem {
  id         String          @id @default(uuid())
  scenarioId String
  title      String
  status     ChecklistStatus @default(PENDING)
  scenario   Scenario        @relation(fields: [scenarioId], references: [id])
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String
  plan      Plan      @default(FREE)
  status    SubStatus @default(ACTIVE)
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id])
}